                              "name": "Text",
                              "fill": "#ffffffa3",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Art is not a mirror to reflect the world, but\na hammer with which to shape it. Elara\nVox operates at the intersection of\ndecaying urban landscapes and the\npristine digital frontier.",
                              "lineHeight": 1.625,
                              "textAlignVertical": "middle",
                              "fontFamily": "Inter",
                              "fontSize": 18,
                              "fontWeight": "normal"
                            }
