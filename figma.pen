                              "id": "dXshm",
                              "name": "Text",
                              "fill": "#ffffffa3",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Utilizing generative algorithms, industrial\nwaste, and street-level vandalism\ntechniques, Vox challenges the\nownership of aesthetic spaces in the 21st\ncentury.",
                              "lineHeight": 1.625,
                              "textAlignVertical": "middle",
                              "fontFamily": "Inter",
                              "fontSize": 18,
                              "fontWeight": "normal"
                            }
